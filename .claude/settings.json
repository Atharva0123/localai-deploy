      "Bash(Start-Process*)",
      "Bash(powershell*-enc*)",
      "Bash(cmd /c*)",
      "Bash(eval*)",
      "Bash(python -c*)",
      "Bash(python3 -c*)",
      "Bash(pip install*)",
      "Bash(ssh*)",
      "Bash(netcat*)",
      "Bash(nmap*)",
      "Bash(sudo*)",
      "Bash(taskkill*)",
      "Bash(Stop-Process*)",
      "Bash(reg *)",
      "Bash(schtasks*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)"
